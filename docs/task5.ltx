\section{Анализ датасетов}

\subsection{MetArt (эротический контент)}

\textbf{Наблюдаемые биологические параметры:}
\begin{itemize}
    \item антропометрические данные (рост, вес, пропорции);
    \item фенотипические признаки (цвет волос, глаз, кожи);
    \item возрастные характеристики;
    \item поза, мимика, жесты.
\end{itemize}

\textbf{Биополитические аспекты (ненаблюдаемые):}
\begin{itemize}
    \item условия контракта и размер оплаты;
    \item наличие принуждения или давления;
    \item согласие на конкретные действия;
    \item влияние редакционной политики платформы;
    \item гендерные и социальные нормы, формирующие эстетику.
\end{itemize}

